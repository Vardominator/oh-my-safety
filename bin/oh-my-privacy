#!/bin/bash
# oh-my-privacy - DEPRECATED compatibility shim.
# The project was renamed to oh-my-safety. This wrapper forwards to it and
# will be removed in a future release.

echo "oh-my-privacy has been renamed to oh-my-safety; this alias will be removed in a future release." >&2
exec "$(dirname "${BASH_SOURCE[0]}")/oh-my-safety" "$@"
